Options -Indexes
ErrorDocument 404 /404.html

<IfModule mod_alias.c>
    RedirectMatch 410 ^/(blog-left-sidebar|blog-right-sidebar|blog-standard|cart|checkout|faq|index-dark|index-one-page|index2-one-page|index2|index3-one-page|index3|login|pricing|product-details|products|project-details|sign-up|team-details|team|test-i18n|test-db-connection|wishlist)\.(html|php)$
</IfModule>
